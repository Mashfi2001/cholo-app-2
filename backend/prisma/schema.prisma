generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  name                String
  email               String                @unique
  role                Role                  @default(PASSENGER)
  createdAt           DateTime              @default(now())
  password            String?
  updatedAt           DateTime              @updatedAt
  id                  Int                   @id @default(autoincrement())
  status              AccountStatus         @default(ACTIVE)
  suspendedUntil      DateTime?
  banExpiryDate       DateTime?
  banReason           String?
  isBanned            Boolean               @default(false)
  phone               String?
  warningCount        Int                   @default(0)
  bookingRequests     BookingRequest[]      @relation("PassengerBookings")
  complaintsFiled     Complaint[]           @relation("UserComplaintsFiled")
  driverComplaints    Complaint[]           @relation("DriverComplaints")
  passengerComplaints Complaint[]           @relation("PassengerComplaints")
  notifications       Notification[]
  rides               Ride[]
  seatBookings        SeatBooking[]
  systemMessages      SystemMessage[]
  verifications       VerificationRequest[]
  warnings            Warning[]
  sentMessages        RideMessage[]         @relation("SentMessages")
  receivedMessages    RideMessage[]         @relation("ReceivedMessages")
}

model Ride {
  departureTime    DateTime
  createdAt        DateTime         @default(now())
  destination      String
  destinationLat   Float?
  destinationLng   Float?
  origin           String
  originLat        Float?
  originLng        Float?
  routeDistanceKm  Float?
  routeDurationMin Float?
  seats            Int              @default(4)
  status           RideStatus       @default(PLANNED)
  updatedAt        DateTime         @updatedAt
  id               Int              @id @default(autoincrement())
  driverId         Int
  currentLat       Float?
  currentLng       Float?
  routePolyline    String?
  totalFare        Float            @default(0)
  bookingRequests  BookingRequest[]
  complaints       Complaint[]
  driver           User             @relation(fields: [driverId], references: [id])
  seatBookings     SeatBooking[]
  messages         RideMessage[]
}

model RideMessage {
  id         Int      @id @default(autoincrement())
  rideId     Int
  senderId   Int
  receiverId Int
  content    String
  createdAt  DateTime @default(now())
  
  ride     Ride @relation(fields: [rideId], references: [id])
  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model BookingRequest {
  id          Int           @id @default(autoincrement())
  rideId      Int
  passengerId Int
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  passenger   User          @relation("PassengerBookings", fields: [passengerId], references: [id])
  ride        Ride          @relation(fields: [rideId], references: [id])

  @@unique([rideId, passengerId])
}

model VerificationRequest {
  id              Int                @id @default(autoincrement())
  userId          Int
  documentType    DocumentType       @default(NID)
  documentUrl     String?
  status          VerificationStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  documentPath    String?
  extractedData   Json?
  user            User               @relation(fields: [userId], references: [id])
}

model SystemMessage {
  id        Int           @id @default(autoincrement())
  type      MessageType   @default(ANNOUNCEMENT)
  title     String
  content   String
  status    MessageStatus @default(ACTIVE)
  createdBy Int
  expiresAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  admin     User          @relation(fields: [createdBy], references: [id])
}

model BroadcastMessage {
  id        Int           @id @default(autoincrement())
  title     String
  content   String
  type      BroadcastType
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  expiresAt DateTime?
}

model SeatBooking {
  id            Int       @id @default(autoincrement())
  rideId        Int
  userId        Int
  seatNo        Int
  fare          Float     @default(0)
  paymentMethod String?
  paymentPhone  String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  ride          Ride      @relation(fields: [rideId], references: [id])
  user          User      @relation(fields: [userId], references: [id])

  @@unique([rideId, seatNo])
}

model Complaint {
  id            Int       @id @default(autoincrement())
  driverId      Int?
  passengerId   Int?
  complainantId Int?
  rideId        Int
  title         String
  description   String
  severity      String    @default("MEDIUM")
  status        String    @default("PENDING")
  type          String    @default("DRIVER_COMPLAINT")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  metadata      Json?
  complainant   User?     @relation("UserComplaintsFiled", fields: [complainantId], references: [id])
  driver        User?     @relation("DriverComplaints", fields: [driverId], references: [id])
  passenger     User?     @relation("PassengerComplaints", fields: [passengerId], references: [id])
  ride          Ride      @relation(fields: [rideId], references: [id])
  warnings      Warning[]

  @@index([driverId])
  @@index([passengerId])
  @@index([complainantId])
  @@index([rideId])
  @@index([status])
}

model Warning {
  id          Int       @id @default(autoincrement())
  userId      Int
  complaintId Int
  message     String
  issuedBy    Int
  createdAt   DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([complaintId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("INFO")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum Role {
  PASSENGER
  DRIVER
  ADMIN
}

enum RideStatus {
  PLANNED
  ONGOING
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  NID
  DRIVERS_LICENSE
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum MessageType {
  ANNOUNCEMENT
  ALERT
  MAINTENANCE
}

enum MessageStatus {
  ACTIVE
  ARCHIVED
  EXPIRED
}

enum BroadcastType {
  ANNOUNCEMENT
  ALERT
  MAINTENANCE
}
