generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PASSENGER
  DRIVER
  ADMIN
}

enum RideStatus {
  PLANNED
  ONGOING
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  NID
  DRIVERS_LICENSE
}

model User {
  id              Int              @id @default(autoincrement())
  name            String
  email           String           @unique
  password        String?
  role            Role             @default(PASSENGER)
  rides           Ride[]
  bookingRequests BookingRequest[] @relation("PassengerBookings")
  verifications   VerificationRequest[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Ride {
  id               Int               @id @default(autoincrement())
  driverId         Int
  origin           String
  destination      String

  originLat        Float?
  originLng        Float?
  destinationLat   Float?
  destinationLng   Float?
  routePolyline    String?
  currentLat       Float?
  currentLng       Float?

  routeDistanceKm  Float?
  routeDurationMin Float?

  departureTime    DateTime
  seats            Int              @default(4)
  status           RideStatus       @default(PLANNED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  driver           User             @relation(fields: [driverId], references: [id])
  bookingRequests  BookingRequest[]
}

model BookingRequest {
  id          Int           @id @default(autoincrement())
  rideId       Int
  passengerId  Int
  status       BookingStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  ride         Ride          @relation(fields: [rideId], references: [id])
  passenger     User          @relation("PassengerBookings", fields: [passengerId], references: [id])

  @@unique([rideId, passengerId])
}

model VerificationRequest {
  id              Int                @id @default(autoincrement())
  userId          Int
  documentType    DocumentType       @default(NID)
  documentUrl     String?            // Keep for backward compatibility, but will be null for new uploads
  documentPath    String?            // Local file path for uploaded documents
  extractedData   Json?              // Extracted data from OCR
  status          VerificationStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user            User               @relation(fields: [userId], references: [id])
}
