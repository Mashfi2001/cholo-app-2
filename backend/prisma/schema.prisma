generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PASSENGER
  DRIVER
  ADMIN
}

enum RideStatus {
  PLANNED
  ONGOING
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  NID
  DRIVERS_LICENSE
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum MessageType {
  ANNOUNCEMENT
  ALERT
  MAINTENANCE
}

enum MessageStatus {
  ACTIVE
  ARCHIVED
  EXPIRED
}

enum BroadcastType {
  ANNOUNCEMENT
  ALERT
  MAINTENANCE
}

model User {
  id                  Int                     @id @default(autoincrement())
  name                String
  email               String                  @unique
  password            String?
  phone               String?
  role                Role                    @default(PASSENGER)
  status              AccountStatus           @default(ACTIVE)
  suspendedUntil      DateTime?
  warningCount        Int                     @default(0)
  isBanned            Boolean                 @default(false)
  banReason           String?
  banExpiryDate       DateTime?
  rides               Ride[]
  systemMessages      SystemMessage[]
  bookingRequests     BookingRequest[]        @relation("PassengerBookings")
  verifications       VerificationRequest[]
  seatBookings        SeatBooking[]
  driverComplaints    Complaint[]             @relation("DriverComplaints")
  passengerComplaints Complaint[]             @relation("PassengerComplaints")
  warnings            Warning[]
  notifications       Notification[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
}

model Ride {
  id               Int               @id @default(autoincrement())
  driverId         Int
  origin           String
  destination      String

  originLat        Float?
  originLng        Float?
  destinationLat   Float?
  destinationLng   Float?
  routePolyline    String?
  currentLat       Float?
  currentLng       Float?

  routeDistanceKm  Float?
  routeDurationMin Float?

  departureTime    DateTime
  seats            Int               @default(4)
  status           RideStatus        @default(PLANNED)
  totalFare        Float             @default(0)

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  driver           User              @relation(fields: [driverId], references: [id])

  bookingRequests  BookingRequest[]

  seatBookings     SeatBooking[]
  complaints       Complaint[]
}

model BookingRequest {
  id          Int           @id @default(autoincrement())
  rideId      Int
  passengerId Int
  status      BookingStatus @default(PENDING)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  ride        Ride          @relation(fields: [rideId], references: [id])

  passenger   User          @relation("PassengerBookings", fields: [passengerId], references: [id])

  @@unique([rideId, passengerId])
}

model VerificationRequest {
  id              Int                 @id @default(autoincrement())
  userId          Int
  documentType    DocumentType        @default(NID)
  documentUrl     String?
  documentPath    String?
  extractedData   Json?
  status          VerificationStatus   @default(PENDING)
  rejectionReason String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user            User                @relation(fields: [userId], references: [id])
}

model SystemMessage {
  id        Int           @id @default(autoincrement())
  type      MessageType   @default(ANNOUNCEMENT)
  title     String
  content   String
  status    MessageStatus @default(ACTIVE)
  createdBy Int
  expiresAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  admin     User          @relation(fields: [createdBy], references: [id])
}

model BroadcastMessage {
  id        Int           @id @default(autoincrement())
  title     String
  content   String
  type      BroadcastType
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  expiresAt DateTime?
}

model SeatBooking {
  id            Int       @id @default(autoincrement())
  rideId        Int
  userId        Int
  seatNo        Int
  fare          Float     @default(0)
  paymentMethod String?
  paymentPhone  String?
  paidAt        DateTime?

  createdAt DateTime @default(now())

  ride      Ride     @relation(fields: [rideId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([rideId, seatNo])
}

model Complaint {
  id          Int      @id @default(autoincrement())
  driverId    Int
  passengerId Int
  rideId      Int
  title       String
  description String
  severity    String   @default("MEDIUM")
  status      String   @default("PENDING")
  type        String   @default("DRIVER_COMPLAINT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  driver    User      @relation("DriverComplaints", fields: [driverId], references: [id])
  passenger User      @relation("PassengerComplaints", fields: [passengerId], references: [id])
  ride      Ride      @relation(fields: [rideId], references: [id])
  warnings  Warning[]

  @@index([driverId])
  @@index([passengerId])
  @@index([rideId])
  @@index([status])
}

model Warning {
  id          Int      @id @default(autoincrement())
  passengerId Int
  complaintId Int
  message     String
  issuedBy    Int
  createdAt   DateTime @default(now())

  passenger User      @relation(fields: [passengerId], references: [id])
  complaint Complaint @relation(fields: [complaintId], references: [id])

  @@index([passengerId])
  @@index([complaintId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("INFO")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}
